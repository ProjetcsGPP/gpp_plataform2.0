[MASTER]
ignore=migrations,venv,.venv,__pycache__
jobs=0
load-plugins=pylint_django


[MESSAGES CONTROL]
disable=
    C0114,
    C0115,
    C0116,
    R0903,
    R0801,
    W0703,
    C0301,
    W0511,
    E0401,
    E1101,
    C0415


[FORMAT]
max-line-length=120


[BASIC]
good-names=i,j,k,ex,pk,id,qs,User,app_name


[DESIGN]
max-args=10
max-attributes=12
max-public-methods=25
max-locals=20
max-branches=15
max-ancestors=15


[TYPECHECK]
ignored-modules=rest_framework
ignored-classes=QuerySet,Manager


[LOGGING]
logging-format-style=new


[SIMILARITIES]
ignore-imports=yes
ignore-comments=yes


[REPORTS]
output-format=colorized
score=yes
